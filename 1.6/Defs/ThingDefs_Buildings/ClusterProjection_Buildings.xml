<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <ThingDef ParentName="BuildingBase">
    <defName>CP_ProjectionBeacon</defName>
    <label>projection beacon</label>
    <description>A launchable projection beacon built beside a launcher like a transport pod. On landing it establishes temporary map presence, keeps the map visible for a limited time, and then self-destructs.</description>
    <thingClass>ClusterProjection.Building_ProjectionBeacon</thingClass>
    <graphicData>
      <texPath>DropBeacon</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.2,1.2)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <rotatable>false</rotatable>
    <tickerType>Normal</tickerType>
    <altitudeLayer>BuildingOnTop</altitudeLayer>
    <passability>PassThroughOnly</passability>
    <fillPercent>0.5</fillPercent>
    <designationCategory>Misc</designationCategory>
    <uiOrder>2201</uiOrder>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
    <statBases>
      <MaxHitPoints>250</MaxHitPoints>
      <WorkToBuild>1600</WorkToBuild>
      <MarketValue>110</MarketValue>
      <Flammability>0.5</Flammability>
    </statBases>
    <costList>
      <Steel>40</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <comps>
      <li Class="CompProperties_Transporter">
        <compClass>ClusterProjection.CP_CompBeaconTransporter</compClass>
        <restEffectiveness>0.8</restEffectiveness>
        <canChangeAssignedThingsAfterStarting>false</canChangeAssignedThingsAfterStarting>
        <max1PerGroup>true</max1PerGroup>
      </li>
      <li Class="CompProperties_Launchable_TransportPod">
        <compClass>ClusterProjection.CP_CompLaunchableBeacon</compClass>
        <skyfallerLeaving>DropPodLeaving</skyfallerLeaving>
      </li>
    </comps>
    <placeWorkers>
      <li>PlaceWorker_NeedsFuelingPort</li>
      <li>PlaceWorker_NotUnderRoof</li>
    </placeWorkers>
    <researchPrerequisites>
      <li>TransportPod</li>
      <li>ClusterProjection</li>
    </researchPrerequisites>
    <constructionSkillPrerequisite>6</constructionSkillPrerequisite>
    <uiIconScale>0.65</uiIconScale>
    <modExtensions>
      <li Class="ClusterProjection.CP_ProjectionBeaconProperties">
        <mapHoldTicks>60000</mapHoldTicks>
      </li>
    </modExtensions>
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>CP_ClusterProjectionConsole</defName>
    <label>cluster projection console</label>
    <description>Main controller for defining launch areas, staging encapsulation, and launching projected clusters.</description>
    <thingClass>ClusterProjection.Building_ClusterProjectionConsole</thingClass>
    <graphicData>
      <texPath>console</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(4,4)</drawSize>
    </graphicData>
    <drawerType>MapMeshAndRealTime</drawerType>
    <size>(3,3)</size>
    <altitudeLayer>Building</altitudeLayer>
    <tickerType>Normal</tickerType>
    <passability>PassThroughOnly</passability>
    <pathCost>10</pathCost>
    <costList>
      <Steel>100</Steel>
      <ComponentIndustrial>2</ComponentIndustrial>
    </costList>
    <researchPrerequisites>
      <li>ClusterProjection</li>
    </researchPrerequisites>
    <designationCategory>Misc</designationCategory>
    <comps>
      <li Class="CompProperties_Refuelable">
        <compClass>ClusterProjection.CP_CompRefuelable</compClass>
        <fuelCapacity>1000</fuelCapacity>
        <fuelConsumptionRate>0</fuelConsumptionRate>
        <showFuelGizmo>true</showFuelGizmo>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>1000</initialConfigurableTargetFuelLevel>
        <canEjectFuel>true</canEjectFuel>
        <fuelFilter>
          <thingDefs>
            <li>Chemfuel</li>
          </thingDefs>
        </fuelFilter>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
      </li>
      <li Class="CompProperties_Refuelable">
        <compClass>ClusterProjection.CP_CompRefuelable</compClass>
        <fuelCapacity>1000</fuelCapacity>
        <fuelConsumptionRate>0</fuelConsumptionRate>
        <showFuelGizmo>true</showFuelGizmo>
        <targetFuelLevelConfigurable>true</targetFuelLevelConfigurable>
        <initialConfigurableTargetFuelLevel>1000</initialConfigurableTargetFuelLevel>
        <canEjectFuel>true</canEjectFuel>
        <fuelLabel>Steel</fuelLabel>
        <fuelGizmoLabel>CP_Steel</fuelGizmoLabel>
        <fuelFilter>
          <thingDefs>
            <li>Steel</li>
          </thingDefs>
        </fuelFilter>
        <showAllowAutoRefuelToggle>true</showAllowAutoRefuelToggle>
      </li>
      <li Class="CompProperties_AffectedByFacilities">
        <linkableFacilities>
          <li>CP_OilExpansionTank</li>
          <li>CP_SteelExpansionTank</li>
        </linkableFacilities>
      </li>
    </comps>
    <modExtensions>
      <li Class="ClusterProjection.CP_AssemblyProperties">
        <baseSteelConsumption>10</baseSteelConsumption>
        <baseFuelConsumption>0.3</baseFuelConsumption>
        <assemblyHeadSpeedCellsPerTick>0.2</assemblyHeadSpeedCellsPerTick>
        <baseAssemblyTicks>20</baseAssemblyTicks>
        <launchCountdownTicks>180</launchCountdownTicks>
        <maxLaunchRandomDelayTicks>30</maxLaunchRandomDelayTicks>
      </li>
    </modExtensions>
    <!-- <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers> -->
  </ThingDef>

  <ThingDef ParentName="BuildingBase">
    <defName>CP_OilExpansionTank</defName>
    <label>oil expansion tank</label>
    <description>Expands the linked cluster projection console's chemfuel capacity while connected within range.</description>
    <thingClass>ClusterProjection.Building_ClusterExpansionTank</thingClass>
    <graphicData>
      <texPath>oil_expansion_tank</texPath>
      <graphicClass>Graphic_Single</graphicClass>
      <drawSize>(1.95,3.9)</drawSize>
    </graphicData>
    <size>(1,1)</size>
    <altitudeLayer>Building</altitudeLayer>
    <fillPercent>1</fillPercent>
    <passability>Impassable</passability>
    <pathCost>25</pathCost>
    <costList>
      <Steel>40</Steel>
      <ComponentIndustrial>1</ComponentIndustrial>
    </costList>
    <researchPrerequisites>
      <li>ClusterProjection</li>
    </researchPrerequisites>
    <designationCategory>Misc</designationCategory>
    <comps>
      <li Class="CompProperties_Facility">
        <maxSimultaneous>1</maxSimultaneous>
      </li>
    </comps>
    <modExtensions>
      <li Class="ClusterProjection.CP_ClusterCapacityExtension">
        <fuelDef>Chemfuel</fuelDef>
        <capacityBonus>500</capacityBonus>
        <connectionRadius>4.9</connectionRadius>
      </li>
    </modExtensions>
    <!-- <placeWorkers>
      <li>PlaceWorker_ShowFacilitiesConnections</li>
    </placeWorkers> -->
  </ThingDef>

