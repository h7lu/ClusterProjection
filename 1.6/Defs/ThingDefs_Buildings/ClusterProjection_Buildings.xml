  <ThingDef ParentName="BuildingBase">
    <defName>CP_OilExpansionTank</defName>
    <label>oil expansion tank</label>
    <description>Expands the linked cluster projection console's chemfuel capacity while connected.</description>
    <thingClass>ClusterProjection.Building_ClusterExpansionTank</thingClass>
    <minifiedDef>MinifiedThing</minifiedDef>
    <terrainAffordanceNeeded>Medium</terrainAffordanceNeeded>
